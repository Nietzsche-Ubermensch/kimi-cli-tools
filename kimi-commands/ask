#!/usr/bin/env node
/**
 * /ask - Ask anything
 */
const { execSync } = require('child_process');
const args = process.argv.slice(2);

if (args.length === 0 || args[0] === '--help') {
  console.log(`Usage: /ask <question> [--deep]`);
  process.exit(0);
}

const deep = args.includes('--deep');
const question = args.filter(a => !a.startsWith('--')).join(' ');
const tool = deep ? 'perplexity_research' : 'perplexity_ask';
const json = JSON.stringify({ messages: [{role:'user',content:question}] }).replace(/"/g, '\\"');

try {
  execSync(`echo "${json}" | npx -y @anthropic-ai/mcp-tool perplexity-mcp ${tool}`,
    { stdio: ['pipe', 'inherit', 'inherit'] });
} catch { process.exit(1); }
